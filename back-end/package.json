{
  "name": "media-tracker-back-end",
  "version": "1.0.0",
  "description": "Back-End for the Media Tracker app",
  "main": "index.ts",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "nyc node test/run-tests.cjs",
    "start": "node build/index.js",
    "debug": "ts-node-dev -r tsconfig-paths/register --inspect --respawn index.ts",
    "lint": "eslint 'app/**/*.ts' 'test/**/*.ts' index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json && copyfiles -u 2 \"./app/config/MEDIA_TRACKER_BE_CONFIG.json\" \"./build/app/config\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Simone3/MediaTrackerBackEnd.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Simone3/MediaTrackerBackEnd/issues"
  },
  "homepage": "https://github.com/Simone3/MediaTrackerBackEnd#readme",
  "nyc": {
    "extension": [
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "**/*.d.ts",
      "**/*.js",
      "**/*.js.map"
    ],
    "reporter": [
      "html"
    ],
    "all": true
  },
  "mocha": {
    "timeout": 10000
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/cls-hooked": "4.3.9",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-mung": "0.5.5",
    "@types/mocha": "10.0.10",
    "@types/node": "25.6.0",
    "@types/sinon": "21.0.1",
    "@types/validator": "13.15.10",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "chai": "6.2.2",
    "chai-http": "5.1.2",
    "copyfiles": "2.4.1",
    "eslint": "10.2.1",
    "eslint-plugin-jsdoc": "62.9.0",
    "mocha": "11.7.5",
    "nock": "14.0.13",
    "nyc": "18.0.0",
    "sinon": "21.1.2",
    "ts-mocha": "11.1.0",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "axios": "1.15.2",
    "class-transformer": "0.5.1",
    "class-transformer-validator": "0.9.1",
    "class-validator": "0.15.1",
    "cors": "2.8.6",
    "exit-hook": "5.1.0",
    "express": "5.2.1",
    "express-http-context": "2.0.1",
    "express-mung": "0.5.1",
    "firebase-admin": "13.8.0",
    "log4js": "6.9.1",
    "mongoose": "9.5.0",
    "reflect-metadata": "0.2.2",
    "uuid": "14.0.0"
  }
}
